  "keyFeatures": [
    "ReActAgent with multi-provider LLM support (OpenAI, Anthropic, Gemini, OpenRouter)",
    "Automatic parallel task-graph runtime via @agent_task decorator",
    "One-command local serving and cloud deployment with motus serve / motus deploy",
    "MCP server integration for external tool consumption",
    "Docker sandbox for isolated code execution",
    "Automatic distributed tracing with HTML viewer and OpenTelemetry export",
    "Drop-in compatibility with OpenAI Agents SDK, Anthropic SDK, and Google ADK",
    "Prompt caching, structured output, and guardrails built in"
  ],
  "publicApiSurface": [
    "ReActAgent",
    "@agent_task",
    "@tool / @tools",
    "FunctionTool",
    "MCPSession",
